# ─── World App ───────────────────────────────────────────────
# App ID from developer.worldcoin.org (format: app_xxxxx)
NEXT_PUBLIC_APP_ID=app_YOUR_REAL_APP_ID

# Wallet address that receives payments (checksummed EVM address)
NEXT_PUBLIC_RECIPIENT_ADDRESS=0xYOUR_REAL_RECIPIENT_ADDRESS

# API key from Developer Portal (for confirm-payment verification)
DEV_PORTAL_API_KEY=your_dev_portal_api_key

# ─── World Chain Mainnet (chain_id 480) ──────────────────────
NEXT_PUBLIC_CHAIN_ID=480
NEXT_PUBLIC_WLD_TOKEN=0x2cFc85d8E48F8EAB294be644d9E25C3030863003
NEXT_PUBLIC_USDC_TOKEN=0x79A02482A880bCE3F13e09Da970dC34db4CD24d1

# Action ID registered in Developer Portal
WORLD_ACTION_ID=verify-user

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─── Database ────────────────────────────────────────────────
# Postgres connection string (for nullifier deduplication)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Rate Limiting (Upstash Redis) ───────────────────────────
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
