# ── World ID ───────────────────────────────────────────────────
WORLD_APP_ID=app_xxxxxxxxxxxx          # developer.worldcoin.org — server-only (no NEXT_PUBLIC_)
WORLD_ACTION_ID=nexus-trust-payment-2026

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/nexus_trust

# ── Upstash Redis (rate limiting + analytics) ──────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ── App config ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nexus-trust.vercel.app
NEXT_PUBLIC_PAYMENT_RECEIVER=0x...         # Treasury wallet (non-custodial receipts)
CONSENT_VERSION=v1                         # Bump on T&C/Privacy text change → forces re-consent

# ── Geo / jurisdictions ────────────────────────────────────────
# Allowlist ISO 3166-1 alpha-2 — excluye US (money transmitter risk) y OFAC
TARGET_JURISDICTIONS=ES,MX,CO,AR,PE,CL,EC,GT,HN,BO,PY,UY,BR,PT

# ── Agent brain ────────────────────────────────────────────────
AGENT_CRON_SECRET=xxxx                     # Shared with Vercel cron Authorization header
GROK_API_KEY=xxxx                          # xAI Grok for yield signal analysis
DEFILLAMA_BASE_URL=https://yields.llama.fi

# ── Vercel ─────────────────────────────────────────────────────
VERCEL_TOKEN=xxxx
