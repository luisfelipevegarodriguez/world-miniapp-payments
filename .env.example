# ── World ID ───────────────────────────────────────────
WORLD_APP_ID=app_xxxxxxxxxxxx          # developer.worldcoin.org — server-only
WORLD_ACTION_ID=nexus-trust-payment-2026

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/db

# ── Upstash Redis (rate limiting) ───────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx

# ── App config ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://nexus-trust.vercel.app
CONSENT_VERSION=v1                    # Bump when T&C/Privacy text changes

# ── Jurisdicciones objetivo (ISO 3166-1 alpha-2) ─────────────
# Excluye US por defecto (regulación cripto / money transmitter risk)
# Excluye OFAC sanctioned: CU,IR,KP,RU,SY
TARGET_JURISDICTIONS=ES,MX,CO,AR,PE,CL,EC,GT,HN,BO,PY,UY
